# =========================================================================
# MediGuard Backend - Environment Variable Template
# =========================================================================
# Copy this file to `.env` (which is gitignored) and fill in real values:
#
#     copy .env.example .env       (Windows)
#     cp .env.example .env         (Unix)
#
# All variables are loaded by `app/core/config.py` via pydantic-settings.
# Names are case-insensitive at load time.
# =========================================================================

# ---------- Application ----------

# Human-readable application name (shown in OpenAPI docs and logs).
APP_NAME=MediGuard API

# Which environment this instance is running in.
# Allowed values: development | staging | production | test
APP_ENV=development

# Enable debug mode (verbose errors, auto-reload). Never enable in production.
DEBUG=false


# ---------- Server ----------

# Bind host. Use 127.0.0.1 for local-only, 0.0.0.0 inside containers.
HOST=127.0.0.1

# Bind port (1-65535).
PORT=8000


# ---------- Logging ----------

# Log verbosity. One of: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Render logs as JSON (true) or human-readable console (false).
# Recommended: true in production, false in development.
LOG_JSON=false


# ---------- Database ----------

# SQLAlchemy connection URL.
# Local dev default: SQLite file in the backend directory.
# Production example: postgresql+psycopg://user:pass@host:5432/mediguard
DATABASE_URL=sqlite:///./mediguard.db


# ---------- Security ----------

# Secret key used for signing JWTs. MUST be a long random string in production.
# Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_IN_PRODUCTION

# Access-token validity, in minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=30
